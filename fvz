-- Loop Principal (Heartbeat para performance)
RunService.Heartbeat:Connect(function()
    if not Character or not Root then return end
    
    -- WalkSpeed & Jump
    Humanoid.WalkSpeed = Config.WalkSpeed
    Humanoid.JumpPower = Config.JumpPower
    
    -- Fly Logic
    if Config.Fly then
        Root.Velocity = Vector3.new(0, 0.1, 0) -- Cancela gravidade simples
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then Root.Velocity = Vector3.new(0, 50, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then Root.Velocity = Vector3.new(0, -50, 0) end
    end

    -- NoClip
    if Config.NoClip then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    -- Ping Update
    PingLabel.Text = "Ping Atual: " .. math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) .. " ms"

    -- Auto Farm Básico (Pseudo-lógica para Blox Fruits)
    if Config.AutoFarm then
        local target = nil
        local dist = math.huge
        for _, enemy in pairs(workspace.Enemies:GetChildren()) do -- Estrutura comum em Blox Fruits
            if enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                local d = (enemy.HumanoidRootPart.Position - Root.Position).Magnitude
                if d < dist then dist = d; target = enemy end
            end
        end
        
        if target then
            Root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 5) -- Fica na frente do mob
            -- Simula ataque (Depende do Remote do jogo, ex: Combat)
            local tool = Player.Character:FindFirstChildOfClass("Tool")
            if tool then tool:Activate() end
        end
    end
end)

-- Sistema de ESP moderno com Highlights
task.spawn(function()
    while task.wait(1) do
        if Config.ESP_Players then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and not p.Character:FindFirstChild("Highlight") then
                    local h = Instance.new("Highlight", p.Character)
                    h.FillColor = Colors.Primary
                    h.OutlineColor = Color3.new(1,1,1)
                    h.FillTransparency = 0.5
                end
            end
        else
            for _, p in pairs(Players:GetPlayers()) do
                if p.Character and p.Character:FindFirstChild("Highlight") then
                    p.Character.Highlight:Destroy()
                end
            end
        end
        
        -- ESP Frutas
        if Config.ESP_Fruits then
            for _, obj in pairs(workspace:GetChildren()) do
                if obj.Name:find("Fruit") and not obj:FindFirstChild("Highlight") then
                    local h = Instance.new("Highlight", obj)
                    h.FillColor = Colors.Success
                    h.FillTransparency = 0.2
                end
            end
        end
    end
end)

