local function SetupTabs()
    for i, name in pairs({"Personagem", "Servidor", "ESP", "Música"}) do
        local TabBtn = Instance.new("TextButton")
        TabBtn.Size = UDim2.new(0, 120, 1, 0)
        TabBtn.BackgroundTransparency = 1
        TabBtn.Text = name
        TabBtn.Font = Enum.Font.GothamMedium
        TabBtn.TextColor3 = i == 1 and Colors.Primary or Colors.TextSecondary
        TabBtn.TextSize = 13
        TabBtn.Parent = TabHolder

        TabBtn.MouseButton1Click:Connect(function()
            for _, p in pairs(Pages) do p.Visible = false end
            for _, b in pairs(TabHolder:GetChildren()) do
                if b:IsA("TextButton") then 
                    TweenService:Create(b, TweenInfo.new(0.2), {TextColor3 = Colors.TextSecondary}):Play()
                end
            end
            Pages[name].Visible = true
            TweenService:Create(TabBtn, TweenInfo.new(0.2), {TextColor3 = Colors.Primary}):Play()
        end)
    end
    Pages["Personagem"].Visible = true
end

SetupTabs()

