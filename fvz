RunService.Stepped:Connect(function()
    -- NoClip
    if _G.Config.NoClip and Player.Character then
        for _, part in pairs(Player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    
    -- Auto Farm Logic
    if _G.Config.AutoFarm then
        pcall(function()
            local Target = nil
            local Dist = math.huge
            
            -- Busca inimigos nas pastas comuns do Blox Fruits
            for _, enemy in pairs(workspace.Enemies:GetChildren()) do
                if enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                    local d = (enemy.HumanoidRootPart.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                    if d < Dist then
                        Dist = d
                        Target = enemy
                    end
                end
            end
            
            if Target then
                -- Teleporta para CIMA do mob para não levar dano
                Player.Character.HumanoidRootPart.CFrame = Target.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0)
                -- Simula Clique
                VirtualUser:CaptureController()
                VirtualUser:ClickButton1(Vector2.new(851, 158))
            end
        end)
    end
    
    -- Fly Logic
    if _G.Config.Fly then
        Player.Character.HumanoidRootPart.Velocity = Vector3.new(0, 1, 0)
    end
end)

