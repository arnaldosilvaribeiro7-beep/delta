local Pages = {}
local function NewTab(name, icon)
    local TabBtn = Instance.new("TextButton", TabScroll)
    TabBtn.Size = UDim2.new(0.85, 0, 0, 42)
    TabBtn.BackgroundColor3 = Colors.CardBG
    TabBtn.BorderSizePixel = 0
    TabBtn.Text = icon .. "  " .. name
    TabBtn.Font = Enum.Font.GothamMedium
    TabBtn.TextSize = 13
    TabBtn.TextColor3 = Colors.Text
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.TextTransparency = 0
    Instance.new("UICorner", TabBtn).CornerRadius = UDim.new(0, 8)
    
    local Page = Instance.new("ScrollingFrame", PageContainer)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ScrollBarThickness = 2
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    Page.ScrollBarImageColor3 = Colors.Accent
    local PageLayout = Instance.new("UIListLayout", Page)
    PageLayout.Padding = UDim.new(0, 6)
    PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Page.CanvasSize = UDim2.fromOffset(0, PageLayout.AbsoluteContentSize.Y + 15)
    end)

    TabBtn.MouseButton1Click:Connect(function()
        for _, pg in pairs(Pages) do pg.Visible = false end
        Page.Visible = true
        for _, child in pairs(TabScroll:GetChildren()) do
            if child:IsA("TextButton") then
                TweenService:Create(child, TweenInfo.new(0.2), {BackgroundColor3 = Colors.CardBG, TextColor3 = Colors.Text}):Play()
            end
        end
        TweenService:Create(TabBtn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent, TextColor3 = Color3.new(1,1,1)}):Play()
    end)

    Pages[name] = Page
    -- Atualiza tamanho do scroll
    local function updateCanvas()
        local totalHeight = 0
        for _, child in pairs(TabScroll:GetChildren()) do
            if child:IsA("TextButton") then
                totalHeight = totalHeight + child.AbsoluteSize.Y + TabList.Padding.Offset
            end
        end
        TabScroll.CanvasSize = UDim2.fromOffset(0, totalHeight + 10)
    end
    TabBtn:GetPropertyChangedSignal("AbsoluteSize"):Connect(updateCanvas)
    updateCanvas()
    return Page
end

