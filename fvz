local function TeleportTo(cf)
    if Character and HumanoidRootPart then
        local distance = (cf.Position - HumanoidRootPart.Position).Magnitude
        local tweenTime = math.clamp(distance / 400, 0.5, 3)
        local tween = TweenService:Create(HumanoidRootPart, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = cf})
        tween:Play()
    end
