local Pages = {}

local function CreatePage(name)
    local Page = Instance.new("ScrollingFrame", Content)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.CanvasSize = UDim2.new(0, 0, 2, 0)
    Page.ScrollBarThickness = 4
    Page.Visible = false
    
    local Layout = Instance.new("UIListLayout", Page)
    Layout.Padding = UDim.new(0, 12)
    
    Pages[name] = Page
    
    local TabBtn = Instance.new("TextButton", TabHolder)
    TabBtn.Size = UDim2.new(0, 140, 1, 0)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name
    TabBtn.Font = Enum.Font.GothamBold
    TabBtn.TextSize = 16 -- Letras maiores
    TabBtn.TextColor3 = Colors.Text
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end
        Page.Visible = true
    end)
    
    return Page
end

-- Componentes Visuais (Toggle e Slider com Letras Maiores)
local function NewToggle(parent, text, config_key, callback)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(1, 0, 0, 55)
    Frame.BackgroundColor3 = Colors.CardBG
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Text = text
    Label.Size = UDim2.new(1, -70, 1, 0)
    Label.Position = UDim2.fromOffset(15, 0)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 18 -- Aumentado
    Label.TextColor3 = Colors.Text
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1
    
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.fromOffset(50, 25)
    Btn.Position = UDim2.new(1, -65, 0.5, -12)
    Btn.BackgroundColor3 = Colors.Border
    Btn.Text = ""
    local Corner = Instance.new("UICorner", Btn)
    Corner.CornerRadius = UDim.new(1, 0)
    
    local Circle = Instance.new("Frame", Btn)
    Circle.Size = UDim2.fromOffset(21, 21)
    Circle.Position = UDim2.fromOffset(2, 2)
    Circle.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Circle).CornerRadius = UDim.new(1, 0)
    
    Btn.MouseButton1Click:Connect(function()
        _G.Config[config_key] = not _G.Config[config_key]
        local active = _G.Config[config_key]
        TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = active and Colors.Primary or Colors.Border}):Play()
        TweenService:Create(Circle, TweenInfo.new(0.2), {Position = active and UDim2.fromOffset(27, 2) or UDim2.fromOffset(2, 2)}):Play()
        callback(active)
    end)
end

local function NewButton(parent, text, callback)
    local Btn = Instance.new("TextButton", parent)
    Btn.Size = UDim2.new(1, 0, 0, 50)
    Btn.BackgroundColor3 = Colors.Primary
    Btn.Text = text
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 18
    Btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 8)
    Btn.MouseButton1Click:Connect(callback)
end

