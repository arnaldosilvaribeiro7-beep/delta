                        tool:Activate()
                        -- Remotes do Blox Fruits costumam requerer disparos repetidos
                        game:GetService("ReplicatedStorage").Remotes.Validator:FireServer(math.random(1,9999))
                    end
                end
            end
        end
    end
end)

